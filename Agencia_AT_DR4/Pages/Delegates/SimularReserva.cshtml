@page
@model Agencia_AT_DR4.Pages.Delegates.SimularReservaModel
@{
    ViewData["Title"] = "Exercício 3 — Func com Lambda";
}

<h2>Exercício 3 — Simulação de Valor de Reserva</h2>
<p class="text-muted">Informe a quantidade de participantes e o preço do pacote para calcular o valor total.</p>

<form method="post" style="max-width: 400px;">
    <div class="mb-3">
        <label asp-for="Participantes" class="form-label">Quantidade de Participantes</label>
        <input asp-for="Participantes" class="form-control" type="number" placeholder="Ex: 3" />
        <span asp-validation-for="Participantes" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="PrecoPacote" class="form-label">Preço do Pacote por Pessoa (R$)</label>
        <input asp-for="PrecoPacote" class="form-control" type="number" step="0.01" placeholder="Ex: 1500.00" />
        <span asp-validation-for="PrecoPacote" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Simular</button>
    <a asp-page="/Index" class="btn btn-secondary">Voltar</a>
</form>

@if (Model.ValorTotal.HasValue)
{
    <div class="alert alert-success mt-4" style="max-width: 400px;">
        <p>Participantes: <strong>@Model.ParticipantesExibir</strong></p>
        <p>Preço por pessoa: <strong>R$ @Model.PrecoPacoteExibir!.Value.ToString("F2")</strong></p>
        <hr />
        <p>Valor total da reserva: <strong>R$ @Model.ValorTotal.Value.ToString("F2")</strong></p>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}