@page
@model Agencia_AT_DR4.Pages.PacoteManager.CreatePacoteModel
@{
    ViewData["Title"] = "Exercício 6 — Cadastro de Pacote";
}

<h2>Exercício 6 — Cadastro de Pacote Turístico</h2>
<p class="text-muted">Preencha os dados para cadastrar um novo pacote turístico.</p>

@if (!ModelState.IsValid && ModelState.ErrorCount > 0)
{
    <div class="alert alert-danger" style="max-width: 500px;">
        @foreach (var erro in ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-0">@erro.ErrorMessage</p>
        }
    </div>
}

<form method="post" style="max-width: 500px;">
    <div class="mb-3">
        <label asp-for="Input.Titulo" class="form-label">Título</label>
        <input asp-for="Input.Titulo" class="form-control" placeholder="Ex: Carnaval no Rio" />
        <span asp-validation-for="Input.Titulo" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.DataInicio" class="form-label">Data de Início</label>
        <input asp-for="Input.DataInicio" class="form-control" type="date" />
        <span asp-validation-for="Input.DataInicio" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.CapacidadeMaxima" class="form-label">Capacidade Máxima</label>
        <input asp-for="Input.CapacidadeMaxima" class="form-control" type="number" placeholder="Ex: 20" />
        <span asp-validation-for="Input.CapacidadeMaxima" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Preco" class="form-label">Preço por Pessoa (R$)</label>
        <input asp-for="Input.Preco" class="form-control" type="number" step="0.01" placeholder="Ex: 2500.00" />
        <span asp-validation-for="Input.Preco" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Cadastrar</button>
    <a asp-page="/Index" class="btn btn-secondary">Voltar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}